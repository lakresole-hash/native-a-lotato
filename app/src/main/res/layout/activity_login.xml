<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_login_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="28dp">

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.6" />

        <androidx.cardview.widget.CardView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="18dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FFFFFF">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@drawable/logo"
                android:contentDescription="@string/logo" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lotato_app_name"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="28dp"
            android:text="@string/lotato_tagline"
            android:textColor="#D8CCF0"
            android:textSize="13sp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutIdentifiant"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:boxStrokeColor="#6D28D9"
                    app:hintTextColor="#6D28D9"
                    android:textColorHint="#9E9E9E"
                    app:startIconDrawable="@drawable/ic_person"
                    app:startIconTint="#6D28D9">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtIdentifiant"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/lotato_hint_identifiant"
                        android:inputType="text"
                        android:textColor="#1A1A1A" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutMotDePasse"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="22dp"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:boxStrokeColor="#6D28D9"
                    app:hintTextColor="#6D28D9"
                    android:textColorHint="#9E9E9E"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="#6D28D9"
                    app:passwordToggleEnabled="true"
                    app:passwordToggleTint="#6D28D9">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtMotDePasse"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/lotato_hint_mdp"
                        android:inputType="textPassword"
                        android:textColor="#1A1A1A" />
                </com.google.android.material.textfield.TextInputLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp">

                    <Button
                        android:id="@+id/btnLogin"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="@string/lotato_btn_login"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:backgroundTint="#6D28D9"
                        android:textColor="#FFFFFF"
                        app:cornerRadius="14dp" />

                    <ProgressBar
                        android:id="@+id/progressLogin"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:indeterminateTint="#FFFFFF"
                        android:visibility="gone" />
                </FrameLayout>

                <TextView
                    android:id="@+id/txtErrorLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:textColor="#DC2626"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            android:text="@string/lotato_footer"
            android:textColor="#9F87C4"
            android:textSize="11sp" />

    </LinearLayout>
</ScrollView>
